# Oracle XE
ORACLE_ROOT_PASSWORD=
ORACLE_APP_USER=
ORACLE_APP_PASSWORD=

# Java (petbuddies-ai)
GEMINI_API_KEY=
ORACLE_URL=jdbc:oracle:thin:@oracle-xe:1521/XEPDB1
ORACLE_USER=
EVOLUTION_API_URL=http://evolution-api:8081
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=

# .NET (PetBuddies-API)
DOTNET_ORACLE_CONN=Data Source=(DESCRIPTION=(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle-xe)(PORT=1521)))(CONNECT_DATA=(SERVER=DEDICATED)(SERVICE_NAME=XEPDB1)));User Id=<ORACLE_APP_USER>;Password=<ORACLE_APP_PASSWORD>;Max Pool Size=3;Min Pool Size=1
MOTOR_API_BASE_URL=http://petbuddies-java:8080

# PostgreSQL (Evolution)
POSTGRES_DB=evolution
POSTGRES_USER=
POSTGRES_PASSWORD=

# Evolution API
EVOLUTION_SERVER_URL=http://<IP_DA_VM>:8081
EVOLUTION_SERVER_PORT=8081
EVOLUTION_DATABASE_URI=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/evolution
EVOLUTION_DEL_INSTANCE=false
